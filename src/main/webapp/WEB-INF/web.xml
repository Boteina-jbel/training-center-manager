<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd" version="5.0">
	<display-name>training-center-manager</display-name>
	
	<welcome-file-list>
	    <welcome-file>index.jsp</welcome-file>
	</welcome-file-list>
	
	<servlet>
	    <servlet-name>controller</servlet-name>
		<servlet-class>org.mql.jee.trainingcenter.web.Controller</servlet-class>
	    <init-param>
	        <param-name>datasource</param-name>
	        <param-value>training_center</param-value>
	    </init-param>
	    <load-on-startup>1</load-on-startup>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>controller</servlet-name>
	    <url-pattern>/training/*</url-pattern>
	</servlet-mapping>
	
	<context-param>
	    <param-name>prefix</param-name>
	    <param-value>/views/</param-value>
	</context-param>
	
	<context-param>
	    <param-name>suffix</param-name>
	    <param-value>.jsp</param-value>
	</context-param>
</web-app>
